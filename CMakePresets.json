{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (vcpkg)",
            "binaryDir": "${sourceDir}/build",
            "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-windows"
            }
        },
        {
            "name": "release",
            "displayName": "Release (vcpkg, pack)",
            "inherits": "default",
            "cacheVariables": {
                "TRUEPBR_PACK": "ON"
            }
        },
        {
            "name": "debug",
            "displayName": "Debug (vcpkg)",
            "inherits": "default"
        },
        {
            "name": "test",
            "displayName": "Test (vcpkg, with unit tests)",
            "inherits": "default",
            "cacheVariables": {
                "TRUEPBR_BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "release",
            "configuration": "Release"
        },
        {
            "name": "debug",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "test",
            "configurePreset": "test",
            "configuration": "Debug"
        }
    ],
    "testPresets": [
        {
            "name": "test",
            "configurePreset": "test",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
